---
import StoreButton from '~/components/ui/StoreButton.astro';

const data = {
  sectionTitle: 'ZINE Lineup',
  sectionLead:
    'Creation, character making, and publishing. Each volume shares the practical “method” developed at PochomLab.',
  zines: [
    {
      slug: 'creation',
      title: '✨Creation',
      subtitle: 'Preserving the creative method as it is.',
      thumb: {
        src: '/images/egaki-sho-cover-01.webp',
        alt: 'Let’s Create Egaki-sho! ZINE — Creation Edition Cover',
        height: 1600,
        width: 900,
      },
      desc: [
        'A record of the thinking, experiments, and decisions behind creating Egaki-sho with generative AI.',
        'From building the production environment to defining AI roles, workflow design, background creation, coloring, and image compositing.',
        'By recording why each choice was made, the method becomes reproducible.',
      ],
      tags: ['Prompt', 'Pipeline', 'Environment'],
      cta: {
        store: 'kdp',
        aria: 'View on KDP',
        label: 'Coming soon',
        url: 'https://www.amazon.co.jp/',
        disable: true,
      },
    },
    {
      slug: 'character-making',
      title: '🧬Character Making',
      subtitle: 'A complete live record of how characters are born.',
      thumb: {
        src: '/images/egaki-sho-cover-02.webp',
        alt: 'Let’s Create Egaki-sho! ZINE — Character Making Edition Cover',
        height: 1600,
        width: 900,
      },
      desc: [
        'How to establish characters capable of sustaining a long-form story using generative AI.',
        'From creating LoRA training materials to learning, testing, failures, and revisions—recorded end to end.',
        'Decision-making for ControlNet, img2img, and model switching is documented to build a reproducible workflow.',
      ],
      tags: ['LoRA', 'ControlNet', 'img2img'],
      highlight: 'Live Record',
      cta: {
        store: 'kdp',
        aria: 'View on KDP',
        label: 'Coming soon',
        url: 'https://www.amazon.co.jp/',
        disable: true,
      },
    },
    {
      slug: 'publishing',
      title: '📘Publishing',
      subtitle: 'Turning creation into a real-world IP.',
      thumb: {
        src: '/images/egaki-sho-cover-03.webp',
        alt: 'Let’s Create Egaki-sho! ZINE — Publishing Edition Cover',
        height: 1600,
        width: 900,
      },
      desc: [
        'Practical publishing processes from EPUB creation to sales registration, based on real experience.',
        'Includes KDP registration inputs, copyright procedures with the Agency for Cultural Affairs, and trademark filing decisions and logs.',
        'The connection from creation to distribution to IP is documented as implementation, not theory.',
      ],
      tags: ['KDP', 'Trademark', 'IP Strategy'],
      cta: {
        store: 'kdp',
        aria: 'View on KDP',
        label: 'Coming soon',
        url: 'https://www.amazon.co.jp/',
        disable: true,
      },
    },
  ],
};

// label: 'View on KDP',
// url: 'https://www.amazon.co.jp/',
---

<section id="zine-cards" class="scroll-mt-20 relative py-16 md:py-24 bg-slate-950 text-neutral-100">
  <div class="container mx-auto max-w-6xl px-4">
    <header class="text-center">
      <h2 class="font-serif text-3xl md:text-4xl tracking-tight">{data.sectionTitle}</h2>
      <p class="mt-5 text-neutral-300 text-sm md:text-base leading-relaxed">{data.sectionLead}</p>
      <div class="mx-auto mt-7 h-px w-20 bg-white/15"></div>
    </header>

    <div class="mt-10 md:mt-14 grid gap-6 md:gap-8 md:grid-cols-3">
      {
        data.zines.map((z) => (
          <article class="group rounded-2xl border border-white/10 bg-white/5 backdrop-blur overflow-hidden flex flex-col">
            <div class="relative">
              <img
                src={z.thumb.src}
                alt={z.thumb.alt}
                class="h-48 w-full object-cover opacity-95 group-hover:opacity-100 transition"
                loading="lazy"
                decoding="async"
                width={z.thumb.width}
                height={z.thumb.height}
              />

              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/35 via-transparent to-transparent" />

              {z.highlight && (
                <div class="absolute left-4 top-4">
                  <span class="inline-flex items-center rounded-full border border-white/15 bg-black/40 px-3 py-1 text-xs tracking-wide text-white/90">
                    {z.highlight}
                  </span>
                </div>
              )}
            </div>

            <div class="p-6 md:p-7 flex flex-col flex-1">
              <h3 class="text-lg md:text-xl font-semibold tracking-wide">{z.title}</h3>
              {z.subtitle && <p class="mt-2 text-sm text-neutral-300 leading-relaxed">{z.subtitle}</p>}

              <div class="mt-5 space-y-3 text-sm md:text-[15px] leading-relaxed text-neutral-200">
                {z.desc.map((line) => (
                  <p class="text-neutral-200/95">{line}</p>
                ))}
              </div>

              <div class="mt-6 flex flex-wrap gap-2">
                {z.tags.map((t) => (
                  <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-neutral-200/90">
                    {t}
                  </span>
                ))}
              </div>

              <div class="mt-auto pt-7 flex flex-wrap gap-3">
                <StoreButton
                  store={z.cta.store}
                  url={z.cta.url}
                  aria={z.cta.aria}
                  label={z.cta.label}
                  fullWidth={true}
                  disabled={z.cta.disable}
                />
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
  <!-- <div class="mt-2 sm:mt-4 text-center">
    <p>
      Japanese edition available on Booth.
    </p>
  </div> -->
</section>
