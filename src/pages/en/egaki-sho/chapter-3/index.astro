---
import Layout from '~/layouts/LandingLayout_EgakiSho_En.astro';
const metadata = {
  title: 'Egaki-sho of the Pochomkin — A Story of Lights | PochomLab',
};
import Hero from '~/components/widgets/HeroText_PochomLab.astro';
import CardText from '~/components/widgets/CardText_PochomLab.astro';
import ToC from '~/components/widgets/ToC_PochomLab.astro';
import ImagePreview from '~/components/widgets/ImagePreview_PochomLab.astro';
import CallToAction from '~/components/widgets/CallToAction_EgakiSho.astro';
import CardLink from '~/components/widgets/CardLink_PochomLab.astro';
---

<Layout metadata={metadata}>
  <!-- 1. Hero -->
  <Hero
    chapter="Chapter 3"
    title="A Wandering Journey"
    subtitle="A small step within uncertainty."
    content="The world begins to open and turn."
  />

  <!-- 2. What you will encounter in this chapter -->
  <CardText
    title="What you will encounter in this chapter"
    items={[
      {
        title: '❄️ Wandering',
        description: 'A path without answers. A moment to pause.',
      },
      {
        title: '👣 A Step',
        description: 'The courage to move forward. Small, yet certain.',
      },
      {
        title: '🌊 An Opening World',
        description: 'Beyond the leap, the scenery begins to change.',
      },
    ]}
  />

  <!-- 3. Lights (keep titles in Japanese for now) -->
  <ToC
    title="Lights of Chapter 3"
    labelWidth="w-24"     
    items={[
      { label: 'Light 17', description: 'ひとりじゃないのに' },
      { label: 'Light 18', description: 'きずのきおく' },
      { label: 'Light 19', description: 'またあるいていこう' },
      { label: 'Light 20', description: 'さよならのさきへ' },
      { label: 'Light 21', description: 'こおったうみ' },
      { label: 'Light 22', description: 'こおりのおくから' },
      { label: 'Light 23', description: 'ふかくふかくつながって' },
      { label: 'Light 24', description: 'やくそくのひかり' },
    ]}
  />

  <ImagePreview
    title="Preview"
    items={[
      {
        src: '/images/egaki-sho-ch3-preview1.webp',
        alt: 'Chapter 3 preview — left page',
        width: 1748,
        height: 2480,
      },
      {
        src: '/images/egaki-sho-ch3-preview2.webp',
        alt: 'Chapter 3 preview — right page',
        width: 1748,
        height: 2480,
      },
    ]}
  />

  <!-- 4. Read / Buy (CTA) -->
  <CallToAction
    title="Read / Buy"
    button={{
      text: 'Read on Kindle (KDP)',
      href: 'https://www.amazon.co.jp/dp/B0GMGP1GPV/',
    }}
  >
    <Fragment slot="content">
      Read Chapter 3 (Lights 17-24) as one complete volume.
      <br />
      Egaki-sho comes to life through the rhythm of space and the breathing of its pages.
    </Fragment>
    <Fragment slot="annotation">
      <i>
        This link leads to the Japanese Kindle edition on Amazon.
        <br />
        English edition coming soon.
      </i>
    </Fragment>
  </CallToAction>

  <!-- 5. Next chapter -->
  <CardLink
    title="Next Chapter"
    chapter="Chapter 4"
    chapterTitle="The Soul Metaverse"
    chapterDescription="Beyond the world that has opened."
    button={{
      text: 'View Chapter 4',
      href: '/en/egaki-sho/chapter-4',
    }}
  />
</Layout>
