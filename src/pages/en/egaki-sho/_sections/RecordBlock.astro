---
type Stat = { value: string; label: string };
type Evolution = {
  src: string;
  alt: string;
  width: number;
  height: number;
  caption: string;
};

const data = {
  // 1) Record
  record: {
    id: 'record',
    stats: [
      { value: '175', label: 'Pages' },
      { value: '4', label: 'Chapters' },
      { value: '35', label: 'Lights' },
      { value: '∞', label: 'Redesigns' },
    ] satisfies Stat[],
    footnote: 'The total distance traveled by generative AI and a human, side by side.',
  },

  // 2) Why
  why: {
    id: 'why',
    title: 'To continue, a new form was invented.',
    lines: [
      'Neither a picture book nor a comic.',
      'A form of expression for long-form storytelling, built light by light with story and reflection.',
      'Each time the fluctuations of generative AI met human intention, the structure was revised.',
      'That is why this work is both a story and a record of its making.',
    ],
  },

  // 3) Process
  process: {
    id: 'process',
    title: 'Redesigned through dialogue.',
    paragraphs: [
      'Generative AI does not always return the same answer. Model updates, parameter changes, even a slight difference in prompts can produce a different world from the same conditions.',
      'Compositions were fixed, lines adjusted, and sometimes the design itself was rebuilt.',
      'The output is not coincidence. It is the accumulation of trials and decisions.',
    ],
  },

  // 4) Evolution
  evolution: {
    id: 'evolution',
    title: 'The structure changed with the evolution.',
    phases: [
      {
        src: '/images/egaki-sho-phase1.webp',
        alt: 'Early phase: dependent on the dimensionality of generative AI',
        width: 400,
        height: 500,
        caption: 'Early phase: dependent on the dimensionality of generative AI',
      },
      {
        src: '/images/egaki-sho-phase2.webp',
        alt: 'Middle phase: redesigned for reproducibility',
        width: 400,
        height: 500,
        caption: 'Middle phase: redesigned for reproducibility',
      },
      {
        src: '/images/egaki-sho-phase3.webp',
        alt: 'Late phase: fluctuations integrated into the worldbuilding',
        width: 400,
        height: 500,
        caption: 'Late phase: fluctuations integrated into the worldbuilding',
      },
    ] satisfies Evolution[],
    closingHtml: `The form emerged within the fluctuations.<br />
<span class="text-gray-400">And with that form, the story begins to walk.</span>`,
  },
};
---

<!-- 3-1. 軌跡：記録（Record） -->
<section
  id={data.record.id}
  class="scroll-mt-0 first-letter:relative isolate overflow-hidden bg-black text-white border-t border-white/5"
>
  <div class="h-16 bg-gradient-to-b from-slate-950 to-black"></div>

  <div class="mx-auto max-w-4xl px-6 py-32 text-center">
    <div class="space-y-14">
      {
        data.record.stats.map((s) => (
          <div>
            <p class="text-6xl md:text-8xl font-light tracking-tight bg-gradient-to-b from-white to-gray-400 bg-clip-text text-transparent">
              {s.value}
            </p>
            <p class="mt-2 text-lg md:text-xl text-gray-400">{s.label}</p>
          </div>
        ))
      }
    </div>

    <p class="mt-24 text-sm md:text-base text-gray-500 tracking-wide">{data.record.footnote}</p>
  </div>

  <div class="h-16 bg-gradient-to-t from-slate-950 to-black"></div>
</section>

<!-- 3-2. Why -->
<section id={data.why.id} class="relative isolate bg-slate-950 text-white">
  <div class="mx-auto max-w-4xl px-6 py-28 md:py-36 text-center">
    <h2 class="text-3xl md:text-5xl font-light tracking-tight">{data.why.title}</h2>

    <div class="mt-10 space-y-4 text-base md:text-lg leading-relaxed text-gray-300">
      {data.why.lines.map((line) => <p>{line}</p>)}
    </div>
  </div>
</section>

<!-- 3-3. Process -->
<section id={data.process.id} class="relative isolate bg-slate-950 text-white">
  <div class="mx-auto max-w-4xl px-6 py-28 md:py-36 text-center">
    <h2 class="text-3xl md:text-5xl font-light tracking-tight">{data.process.title}</h2>

    <div class="mt-10 space-y-5 text-base md:text-lg leading-relaxed text-gray-300">
      {data.process.paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </div>
</section>

<!-- 3-4. Evolution -->
<section id={data.evolution.id} class="relative isolate bg-slate-950 text-white">
  <div class="mx-auto max-w-4xl px-6 py-28 md:py-36 text-center">
    <h2 class="text-3xl md:text-5xl font-light tracking-tight">{data.evolution.title}</h2>

    <div class="mt-16 space-y-24">
      {
        data.evolution.phases.map((ph) => (
          <div class="mx-auto max-w-[400px]">
            <img
              src={ph.src}
              class="w-full rounded-lg"
              alt={ph.alt}
              loading="lazy"
              width={ph.width}
              height={ph.height}
            />
            <p class="mt-6 text-sm md:text-base text-gray-400">{ph.caption}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-24 text-center">
      <p class="text-base md:text-lg leading-relaxed text-gray-300" set:html={data.evolution.closingHtml} />
    </div>
  </div>
</section>
