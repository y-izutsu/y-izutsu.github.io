---
type CTA = {
  label: string;
  href: string;
  variant: "primary" | "secondary";
  disabled?: boolean;
};

const title = "🌳 307の庭 🌳";
const lead = "ZINEから生まれた創作者たちへ。";

const note =
  "ここは、絵書を創る人たちが集う場所です。作品・制作ログ・SNSなどを静かに並べ、文化の足跡を残していきます。";

const bullets: string[] = [
  "掲載できるもの：作品ページ / 制作ログ / SNS（任意）",
  "掲載条件：絵書・ZINEをきっかけに制作したことが分かる内容",
  "掲載方法：フォームから申請 → 掲載（順次）",
];

const boxTitle = "🌱この場所は、まだ育て途中です。";
const boxBodyHtml = `最初は空でもかまいません。<br />“場”があることが、文化の発芽につながります。`;

const ctas: CTA[] = [
  { label: "参加する（掲載申請）", href: "/ja/about#contact-garden-307", variant: "primary", disabled: false },
  { label: "庭を見る", href: "/ja/garden-307", variant: "secondary", disabled: false },
];

const footnote = "※ 参加申請が届き次第、順次掲載していきます。";

const btnClass = (variant: CTA["variant"], disabled?: boolean) =>
  variant === "primary"
    ? `inline-flex items-center justify-center rounded-full bg-white text-neutral-950 px-4 py-2 text-sm font-semibold transition ${
        disabled ? "opacity-40 pointer-events-none" : "hover:bg-white/90"
      }`
    : `inline-flex items-center justify-center rounded-full border border-white/15 bg-white/5 text-white px-4 py-2 text-sm font-semibold transition ${
        disabled ? "opacity-40 pointer-events-none" : "hover:bg-white/10"
      }`;
---

<section id="garden-307" class="relative py-16 md:py-24 bg-slate-950 text-neutral-100">
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-slate-950 via-teal-950/40 to-slate-950"></div>

  <div class="relative container mx-auto max-w-6xl px-4">
    <div class="rounded-3xl border border-white/10 bg-white/5 backdrop-blur p-8 md:p-12">
      <header class="text-center">
        <p class="text-xs tracking-[0.3em] text-white/60 uppercase">Community</p>
        <h2 class="mt-3 font-serif text-3xl md:text-4xl tracking-tight">{title}</h2>
        <p class="mt-5 text-neutral-200 text-base md:text-lg leading-relaxed">{lead}</p>
        <div class="mx-auto mt-7 h-px w-20 bg-white/15"></div>
      </header>

      <div class="mt-10 md:mt-12 grid gap-8 md:grid-cols-2 items-start">
        <div>
          <p class="text-neutral-300 leading-relaxed">{note}</p>

          <ul class="mt-6 space-y-3 text-sm md:text-[15px] text-neutral-200/95">
            {bullets.map((b) => (
              <li class="flex gap-3">
                <span class="mt-1 h-1.5 w-1.5 rounded-full bg-white/40 flex-shrink-0" />
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-2xl border border-white/10 bg-black/10 p-6 md:p-7">
          <h3 class="text-base md:text-lg font-semibold">{boxTitle}</h3>
          <p class="mt-3 text-sm md:text-[15px] leading-relaxed text-neutral-300" set:html={boxBodyHtml} />

          <div class="mt-7 flex flex-wrap gap-3">
            {ctas.map((c) => (
              <a href={c.disabled ? undefined : c.href} class={btnClass(c.variant, c.disabled)}>
                {c.label}
              </a>
            ))}
          </div>

          <p class="mt-4 text-xs text-white/45">{footnote}</p>
        </div>
      </div>
    </div>
  </div>
</section>
