---
import StoreButton from '~/components/ui/StoreButton.astro';

const data = {
  sectionTitle: 'ZINEラインナップ',
  sectionLead: '創作・キャラメイク・出版。PochomLabが実践した「制作の型」を、巻ごとに手渡す。',
  zines: [
    {
      slug: 'creation',
      title: '✨創作編',
      subtitle: '創作の“型”を、そのまま残す。',
      thumb: {
        src: '/images/egaki-sho-cover-01.webp',
        alt: '絵書創ろうよ！ZINE 創作編 表紙サムネイル',
        height: 1600,
        width: 900,
      },
      desc: [
        '生成AIで絵書を生み出すための、思考・試行・判断を記録。',
        '制作環境の構築から、AIの役割分担、制作フロー、背景設計・着彩・画像合成までを整理。',
        '「なぜそれを選んだか」まで残すことで、型が再現可能になる。',
      ],
      tags: ['Prompt', 'Pipeline', 'Environment'],
      cta: {
        store: 'booth',
        aria: '絵書創ろうよ！ZINE（創作編）をBoothで開く',
        label: '準備中',
        url: 'https://booth.pm/ja/',
        disable: true,
      },
    },
    {
      slug: 'character-making',
      title: '🧬キャラクターメイキング編',
      subtitle: 'キャラが生まれる瞬間を、完全実況。',
      thumb: {
        src: '/images/egaki-sho-cover-02.webp',
        alt: '絵書創ろうよ！ZINE キャラクターメイキング編 表紙サムネイル',
        height: 1600,
        width: 900,
      },
      desc: [
        '長編制作に耐えるキャラクターを、生成AIでどう成立させるか。',
        'LoRA素材づくりから学習、検証、破綻と修正までを一気通貫で記録。',
        'ControlNet・img2img・モデル切替の判断基準を言語化し、再現性を上げるための型を実例で残す。',
      ],
      tags: ['LoRA', 'ControlNet', 'img2img'],
      highlight: '完全実況',
      cta: {
        store: 'booth',
        aria: '絵書創ろうよ！ZINE（キャラクターメイキング編）をBoothで開く',
        label: '準備中',
        url: 'https://booth.pm/ja/',
        disable: true,
      },
    },
    {
      slug: 'publishing',
      title: '📘出版編',
      subtitle: '創作を、現実のIPとして成立させる。',
      thumb: {
        src: '/images/egaki-sho-cover-03.webp',
        alt: '絵書創ろうよ！ZINE 出版編 表紙サムネイル',
        height: 1600,
        width: 900,
      },
      desc: [
        '電子書籍化（EPUB）から販売登録まで、出版の実務を実体験ベースで整理。',
        'KDP登録の入力内容、著作権・文化庁手続き、商標出願の判断と作業ログを記録。',
        '「創作→流通→IP」への接続点を、理論ではなく実装として残す。',
      ],
      tags: ['KDP', 'Trademark', 'IP Strategy'],
      cta: {
        store: 'booth',
        aria: '絵書創ろうよ！ZINE（出版編）をBoothで開く',
        label: '準備中',
        url: 'https://booth.pm/ja/',
        disable: true,
      },
    },
  ],
};
        // label: 'Boothで見る',
        // url: 'https://booth.pm/ja/',
---

<section id="zine-cards" class="scroll-mt-20 relative py-16 md:py-24 bg-slate-950 text-neutral-100">
  <div class="container mx-auto max-w-6xl px-4">
    <header class="text-center">
      <h2 class="font-serif text-3xl md:text-4xl tracking-tight">{data.sectionTitle}</h2>
      <p class="mt-5 text-neutral-300 text-sm md:text-base leading-relaxed">{data.sectionLead}</p>
      <div class="mx-auto mt-7 h-px w-20 bg-white/15"></div>
    </header>

    <div class="mt-10 md:mt-14 grid gap-6 md:gap-8 md:grid-cols-3">
      {
        data.zines.map((z) => (
          <article class="group rounded-2xl border border-white/10 bg-white/5 backdrop-blur overflow-hidden flex flex-col">
            <div class="relative">
              <img
                src={z.thumb.src}
                alt={z.thumb.alt}
                class="h-48 w-full object-cover opacity-95 group-hover:opacity-100 transition"
                loading="lazy"
                decoding="async"
                width={z.thumb.width}
                height={z.thumb.height}
              />

              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/35 via-transparent to-transparent" />

              {z.highlight && (
                <div class="absolute left-4 top-4">
                  <span class="inline-flex items-center rounded-full border border-white/15 bg-black/40 px-3 py-1 text-xs tracking-wide text-white/90">
                    {z.highlight}
                  </span>
                </div>
              )}
            </div>

            <div class="p-6 md:p-7 flex flex-col flex-1">
              <h3 class="text-lg md:text-xl font-semibold tracking-wide">{z.title}</h3>
              {z.subtitle && <p class="mt-2 text-sm text-neutral-300 leading-relaxed">{z.subtitle}</p>}

              <div class="mt-5 space-y-3 text-sm md:text-[15px] leading-relaxed text-neutral-200">
                {z.desc.map((line) => (
                  <p class="text-neutral-200/95">{line}</p>
                ))}
              </div>

              <div class="mt-6 flex flex-wrap gap-2">
                {z.tags.map((t) => (
                  <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-neutral-200/90">
                    {t}
                  </span>
                ))}
              </div>

              <div class="mt-auto pt-7 flex flex-wrap gap-3">
                <StoreButton
                  store={z.cta.store}
                  url={z.cta.url}
                  aria={z.cta.aria}
                  label={z.cta.label}
                  fullWidth={true}
                  disabled={z.cta.disable}
                />
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
  <!-- <div class="mt-2 sm:mt-4 text-center">
    <p>
      英語版はAmazon Kindleで入手可能です。
    </p>
  </div> -->
</section>
