---
import Layout from '~/layouts/LandingLayout_EgakiSho_Ja.astro';
const metadata = {
  title: 'ポチョム菌の絵書｜灯の物語｜PochomLab',
};
import Hero from '~/components/widgets/HeroText_PochomLab.astro';
import CardText from '~/components/widgets/CardText_PochomLab.astro';
import ToC from '~/components/widgets/ToC_PochomLab.astro';
import ImagePreview from '~/components/widgets/ImagePreview_PochomLab.astro';
import CallToAction from '~/components/widgets/CallToAction_EgakiSho.astro';
import CardLink from '~/components/widgets/CardLink_PochomLab.astro';
---

<Layout metadata={metadata}>

<!-- 1. Hero（章の顔） -->
<Hero
  chapter="第3章"
  title="まよいの&ensp;たびじ"
  subtitle="まよいの中の、小さな一歩。"
  content="せかいが、ぐるんとひらきはじめる。"
/>

<!-- 2.この章で出会うもの：登場キャラ/舞台/テーマ（カード3つ） -->
<CardText
  title="この章で出会うもの"
  items={[
    {
      title: '❄️まよい',
      description: 'こたえのない道。立ち止まる時間。',
    },
    {
      title: '👣一歩',
      description: 'ふみだす勇気。小さくても確かな前進。',
    },
    {
      title: '🌊ひらける世界',
      description: 'えいっと越えた先で、景色が変わる。',
    },
  ]}
/>


<!-- 3. 灯の目次（第1章） -->
<ToC
  title="灯の目次"
  labelWidth="w-12"  
  items={[
    { label: "17灯", description: "ひとりじゃないのに" },
    { label: "18灯", description: "きずのきおく" },
    { label: "19灯", description: "またあるいていこう" },
    { label: "20灯", description: "さよならのさきへ" },
    { label: "21灯", description: "こおったうみ" },
    { label: "22灯", description: "こおりのおくから" },
    { label: "23灯", description: "ふかくふかくつながって" },
    { label: "24灯", description: "やくそくのひかり" },
  ]}
/> 

<ImagePreview
  title="試し読み"
  items=
  {[
    {
      src: "/images/egaki-sho-ch3-preview1.webp",
      alt: "第3章 試し読み（左ページ）",
      width: 1748,
      height: 2480,
    },
    {
      src: "/images/egaki-sho-ch3-preview2.webp",
      alt: "第3章 試し読み（右ページ）",
      width: 1748,
      height: 2480,
    },
  ]}
/>

<!-- 4. 読む / 買う（CTA） -->
<CallToAction
  title="読む／買う"
  button=
  {{ 
    text: "Kindleで読む（KDP）", 
    href: "https://www.amazon.co.jp/dp/B0GMGP1GPV/"
  }}
>
  <Fragment slot="content">
    第3章（17〜24灯）を、1冊として読む。
    <br>
    余白とページの呼吸まで含めて完成する絵書です。
  </Fragment>
  <Fragment slot="annotation">
    ※ リンク先はAmazon（Kindle）です。
  </Fragment>
</CallToAction>

<!-- 5. 次の章へ：次章カード -->
<CardLink
  title="次の章へ"
  chapter="第4章"
  chapterTitle="たましいの&ensp;メタバース"
  chapterDescription="ひらいた世界の、その奥へ。"
  button={{ 
    text: "第4章を見る", 
    href: "/ja/egaki-sho/chapter-4"
  }}
/>

</Layout>
