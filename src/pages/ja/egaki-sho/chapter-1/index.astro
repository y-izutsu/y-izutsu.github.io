---
import Layout from '~/layouts/LandingLayout_EgakiSho_Ja.astro';
const metadata = {
  title: 'ポチョム菌の絵書｜灯の物語｜PochomLab',
};
import Hero from '~/components/widgets/HeroText_PochomLab.astro';
import CardText from '~/components/widgets/CardText_PochomLab.astro';
import ToC from '~/components/widgets/ToC_PochomLab.astro';
import ImagePreview from '~/components/widgets/ImagePreview_PochomLab.astro';
import CallToAction from '~/components/widgets/CallToAction_EgakiSho.astro';
import CardLink from '~/components/widgets/CardLink_PochomLab.astro';
---

<Layout metadata={metadata}>

<!-- 1. Hero（章の顔） -->
<Hero
  chapter="第1章"
  title="いのちの&ensp;はじまり"
  subtitle="それは、まだ名前のない光だった。"
  content="小さな気づきが、世界を揺らしはじめる。"
/>

<!-- 2.この章で出会うもの：登場キャラ/舞台/テーマ（カード3つ） -->
<CardText
  title="この章で出会うもの"
  items={[
    {
      title: '🐣ピーチョム',
      description: 'まだ何者でもない、小さな灯。',
    },
    {
      title: '🌳はじまりの森',
      description: '層を持つ世界の入口。静かな呼吸。',
    },
    {
      title: '✨気づき',
      description: '最初のDing。魂が震える瞬間。',
    },
  ]}
/>


<!-- 3. 灯の目次（第1章） -->
<ToC
  title="灯の目次"
  labelWidth="w-12"
  items={[
    { label: "01灯", description: "うまれたひかり" },
    { label: "02灯", description: "そのひかりなあに" },
    { label: "03灯", description: "はじめてのみち" },
    { label: "04灯", description: "ちいさなこえ" },
    { label: "05灯", description: "さがしてみたい" },
    { label: "06灯", description: "ひかりのかけら" },
    { label: "07灯", description: "こわくてすすめない" },
    { label: "08灯", description: "ひかりのなえどこ" },
  ]}
/> 

<ImagePreview
  title="試し読み"
  items=
  {[
    {
      src: "/images/egaki-sho-ch1-preview1.webp",
      alt: "第1章 試し読み（左ページ）",
      width: 1748,
      height: 2480,
    },
    {
      src: "/images/egaki-sho-ch1-preview2.webp",
      alt: "第1章 試し読み（右ページ）",
      width: 1748,
      height: 2480,
    },
  ]}
/>

<!-- 4. 読む / 買う（CTA） -->
<CallToAction
  title="読む／買う"
  button=
  {{ 
    text: "Kindleで読む（KDP）", 
    href: "https://www.amazon.co.jp/dp/B0G3Q6C68P/"
  }}
>
  <Fragment slot="content">
    第1章（全8灯）を、1冊として読む。
    <br>
    余白とページの呼吸まで含めて完成する絵書です。
  </Fragment>
  <Fragment slot="annotation">
    ※ リンク先はAmazon（Kindle）です。
  </Fragment>
</CallToAction>

<!-- 5. 次の章へ：次章カード -->
<CardLink
  title="次の章へ"
  chapter="第2章"
  chapterTitle="やさしさの&ensp;たね"
  chapterDescription="こわさの奥で、やさしさが芽吹く。"
  button={{ 
    text: "第2章を見る", 
    href: "/ja/egaki-sho/chapter-2"
  }}
/>

</Layout>
