---
import Layout from '~/layouts/LandingLayout_EgakiSho_Ja.astro';
const metadata = {
  title: 'ポチョム菌の絵書｜灯の物語｜PochomLab',
};
import Hero from '~/components/widgets/HeroText_PochomLab.astro';
import CardText from '~/components/widgets/CardText_PochomLab.astro';
import ToC from '~/components/widgets/ToC_PochomLab.astro';
import ImagePreview from '~/components/widgets/ImagePreview_PochomLab.astro';
import CallToAction from '~/components/widgets/CallToAction_EgakiSho.astro';
//import CardLink from '~/components/widgets/CardLink.astro';
---

<Layout metadata={metadata}>

<!-- 1. Hero（章の顔） -->
<Hero
  chapter="第4章"
  title="たましいの&ensp;メタバース"
  subtitle="たましいが うまれなおす 場所。"
  content="こころの旅が、あらたにひらく。"
/>

<!-- 2.この章で出会うもの：登場キャラ/舞台/テーマ（カード3つ） -->
<CardText
  title="この章で出会うもの"
  items={[
    {
      title: '🌌メタバース',
      description: 'たましいが重なり合う、もうひとつの層。',
    },
    {
      title: '🔁再生',
      description: 'きおくといたみが、光へ変わる瞬間。',
    },
    {
      title: '🚪とびら',
      description: 'うまれなおすための、見えない入口。',
    },
  ]}
/>


<!-- 3. 灯の目次（第1章） -->
<ToC
  title="灯の目次"
  labelWidth="w-12"  
  items={[
    { label: "25灯", description: "はじまりのこえ" },
    { label: "26灯", description: "であいのしずく" },
    { label: "27灯", description: "まよいのほこら" },
    { label: "28灯", description: "ふりかえりのうた" },
    { label: "29灯", description: "ひかりのきおく" },
    { label: "30灯", description: "たましいのゆらぎ" },
    { label: "31灯", description: "でんせつのひかり" },
    { label: "32灯", description: "きみをしってる" },
    { label: "33灯", description: "ひびきのはて" },
    { label: "34灯", description: "たましいのログアウト" },
    { label: "35灯", description: "えいえんのたび" },
  ]}
/> 

<ImagePreview
  title="試し読み"
  items=
  {[
    {
      src: "/images/egaki-sho-ch4-preview1.webp",
      alt: "第4章 試し読み（左ページ）",
      width: 1748,
      height: 2480,
    },
    {
      src: "/images/egaki-sho-ch4-preview2.webp",
      alt: "第4章 試し読み（右ページ）",
      width: 1748,
      height: 2480,
    },
  ]}
/>

<!-- 4. 読む / 買う（CTA） -->
<CallToAction
  title="読む／買う"
  button=
  {{ 
    text: "Kindleで読む（KDP）", 
    href: "https://www.amazon.co.jp/dp/B0GQQ22G87/"
  }}
>
  <Fragment slot="content">
    第4章（25〜35灯）を、1冊として読む。
    <br>
    余白とページの呼吸まで含めて完成する絵書です。
  </Fragment>
  <Fragment slot="annotation">
    ※ リンク先はAmazon（Kindle）です。
  </Fragment>
</CallToAction>

<!-- 5. 次の章へ：次章カード -->
 <!--
<CardLink
  title="次の章へ"
  chapter="第5章"
  chapterTitle="たましいの&ensp;メタバース"
  chapterDescription="ひらいた世界の、その奥へ。"
  button={{ 
    text: "第5章を見る", 
    href: "/egaki-sho/chapter-5"
  }}
/>
 -->
</Layout>
