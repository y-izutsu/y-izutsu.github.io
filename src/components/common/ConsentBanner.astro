---
import { ANALYTICS } from 'astrowind:config';

export interface Props {
  locale?: 'ja' | 'en';
}

const { locale = 'ja' } = Astro.props;

const id = ANALYTICS?.vendors?.googleAnalytics?.id
  ? String(ANALYTICS.vendors.googleAnalytics.id)
  : null;

const isProd = import.meta.env.PROD;

const t = {
  ja: {
    message:
      'このサイトではアクセス解析（Google Analytics）を利用します。Cookie等を用いて利用状況を計測します。',
    reject: '拒否',
    accept: '同意',
  },
  en: {
    message:
      'We use analytics (Google Analytics) to measure site usage using cookies and similar technologies.',
    reject: 'Reject',
    accept: 'Accept',
  },
} as const;

const copy = locale === 'en' ? t.en : t.ja;
---

{isProd && id ? (
  <div id="consent-banner" class="fixed bottom-0 left-0 right-0 z-50 hidden">
    <div class="mx-auto max-w-5xl m-3 rounded-xl border border-white/15 bg-black/55 backdrop-blur-md text-white">
      <div class="flex flex-col md:flex-row md:items-center gap-3 p-4">
        <p class="text-sm text-white/90 leading-relaxed">
          {copy.message}
        </p>

        <div class="flex gap-2 md:ml-auto">
          <button
            id="consent-reject"
            class="px-3 py-2 rounded-lg bg-white/10 hover:bg-white/15 text-sm"
            type="button"
          >
            {copy.reject}
          </button>
          <button
            id="consent-accept"
            class="px-3 py-2 rounded-lg bg-white text-black hover:bg-white/90 text-sm font-semibold"
            type="button"
          >
            {copy.accept}
          </button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const KEY = "pochom_consent";
        const banner = document.getElementById("consent-banner");
        const accept = document.getElementById("consent-accept");
        const reject = document.getElementById("consent-reject");

        function show() { banner.classList.remove("hidden"); }
        function hide() { banner.classList.add("hidden"); }

        // === 1. 保存されているのは "granted" のみ ===
        try {
          const saved = localStorage.getItem(KEY);
          if (saved === "granted") {
            // 同意済み → Consent Mode を復元
            if (typeof window.gtag === "function") {
              console.log('同意済み → Consent Mode を復元');
              window.gtag("consent", "update", { analytics_storage: "granted" });
            }
            return; // バナーを出さない
          }
        } catch { /* empty */ }

        // === 2. 未決定 → バナー表示 ===
        show();

        // === 3. 同意ボタン ===
        accept.addEventListener("click", function () {
          console.log('3. 同意ボタン');
          try { localStorage.setItem(KEY, "granted"); } catch { /* empty */ }

          if (typeof window.gtag === "function") {
            console.log('window.gtag granted 行きます');
            window.gtag("consent", "update", { analytics_storage: "granted" });
          }

          // page_view は astro:page-load が送るのでここでは送らない
          hide();
        });

        // === 4. 拒否ボタン ===
        reject.addEventListener("click", function () {
          console.log('4. 拒否ボタン');
          // "denied" は保存しない（default が denied）
          hide();
        });
      })();
    </script>
  </div>
) : null}
