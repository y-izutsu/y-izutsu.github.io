---
const {
  id,
  imageUrl,
  alt,
  width,
  height,
  backgroundColor = "#020617",
  scrollTarget, // props
} = Astro.props;

// slots（無ければ空）
const title = (await Astro.slots.render("title")) ?? "";
const subtitle = (await Astro.slots.render("subtitle")) ?? "";
const scrollText = (await Astro.slots.render("scrollText")) ?? "";
---

<section class="scroll-mt-28 relative py-32 text-center overflow-hidden" {...(id ? { id } : {})}>
  <img
    src={imageUrl}
    alt={alt}
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    decoding="async"
    width={width}
    height={height}
    fetchpriority="high"
    style={`background-color: ${backgroundColor};`}
  />
  <div class="absolute inset-0 bg-black/40"></div>

  <div class="relative container mx-auto">
    {title && (
      <h1 class="font-serif text-5xl md:text-6xl font-light leading-tight text-white" set:html={title} />
    )}

    <div class="w-12 h-px bg-white/30 mx-auto my-6"></div>

    {subtitle && (
      <p class="mt-6 font-serif text-lg md:text-xl text-white/90" set:html={subtitle} />
    )}
  </div>

  {scrollTarget && scrollText && (
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2">
      <a href={"#" + scrollTarget} class="flex flex-col items-center text-neutral-300/80 dark:text-neutral-200/80">
        <span class="text-sm font-serif tracking-wide" set:html={scrollText} />
        <span class="mt-2 animate-bounce text-2xl">↓</span>
      </a>
    </div>
  )}
</section>
