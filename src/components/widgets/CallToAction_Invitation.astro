---
type CTA = {
  label: string;
  href: string;
};

const { primary, secondary } = Astro.props as {
  primary: CTA;
  secondary?: CTA;
};
---

<section
  id="invitation"
  class="scroll-mt-16 relative overflow-hidden py-20 sm:py-28 bg-neutral-50 dark:bg-neutral-950 text-black dark:text-white"
>
  <!-- glow -->
  <div class="pointer-events-none absolute inset-0 opacity-30 blur-3xl">
    <div
      class="absolute left-1/2 top-1/2 h-[520px] w-[520px]
      -translate-x-1/2 -translate-y-1/2 rounded-full
      bg-black/10 dark:bg-white/10"
    />
  </div>

  <div class="container relative mx-auto px-4">
    <div class="mx-auto max-w-3xl text-center">

      <h2 class="font-serif text-3xl sm:text-4xl font-light tracking-wide">
        <slot name="title" />
      </h2>

      <p class="mt-6 text-xl sm:text-2xl leading-relaxed font-serif text-black/90 dark:text-white/90">
        <slot name="lead" />
      </p>

      <p class="mt-6 text-sm sm:text-base leading-relaxed font-serif text-black/70 dark:text-white/70">
        <slot name="description" />
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">

        <a
          href={primary.href}
          class="inline-flex w-full sm:w-auto items-center justify-center rounded-full px-6 py-3 text-sm font-semibold
          bg-cyan-600 text-white hover:bg-cyan-500
          dark:bg-cyan-500 dark:hover:bg-cyan-400
          focus:outline-none focus:ring-2 focus:ring-cyan-400/50"
        >
          {primary.label}
        </a>

        {secondary && (
          <a
            href={secondary.href}
            class="inline-flex w-full sm:w-auto items-center justify-center
            rounded-full px-6 py-3 text-sm font-semibold
            text-black dark:text-white border border-black/30 dark:border-white/30
            hover:border-black/60 dark:hover:border-white/60
            hover:bg-black/5 dark:hover:bg-white/10 transition"
          >
            {secondary.label}
          </a>
        )}

      </div>

      <p class="mt-12 text-base sm:text-lg font-serif text-black/85 dark:text-white/85">
        <slot name="footer" />
      </p>

    </div>
  </div>
</section>
